DB_URL=jdbc:postgresql://localhost:5432/main_java_template
DB_USERNAME=postgres
DB_PASSWORD=postgres

APP_AUTH_MODE=token
APP_ACCESS_COOKIE_NAME=accessToken
APP_REFRESH_COOKIE_NAME=refreshToken
APP_COOKIE_SAME_SITE=Lax
APP_COOKIE_PATH=/
APP_COOKIE_SECURE=false

# Base64-encoded secrets, minimum 32-byte key material before encoding
APP_JWT_ACCESS_SECRET=REPLACE_WITH_BASE64_SECRET
APP_JWT_REFRESH_SECRET=REPLACE_WITH_BASE64_SECRET
APP_JWT_ACCESS_MINUTES=15
APP_JWT_REFRESH_DAYS=7

# Optional social login support (requires spring.security.oauth2.client.* config)
APP_SOCIAL_AUTH_ENABLED=false

APP_FRONTEND_RESET_PASSWORD_URL=http://localhost:5173/reset-password
APP_MAIL_FROM=no-reply@example.com

# Mail server (use Mailhog/Mailpit locally)
MAIL_HOST=localhost
MAIL_PORT=1025
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_SMTP_AUTH=false
MAIL_STARTTLS_ENABLE=false
